{
  "name": "substack-creator-newsletter-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "test": "vitest run src/__tests__/integration/scenarios.test.ts",
    "test:integration": "vitest run src/__tests__/integration/scenarios.test.ts",
    "test:smoke": "vitest run src/__tests__/smoke/scenarios.smoke.test.ts",
    "test:manual": "vitest run src/__tests__/manual/manual-mode.test.ts",
    "verify:browser": "node --import tsx src/tests/browser/runScenarios.ts",
    "fmt:check": "prettier --check",
    "fmt:write": "prettier --write",
    "validate:fmt": "sh scripts/validate-fmt.sh",
    "validate:build": "sh scripts/validate-build.sh",
    "validate:test": "sh scripts/validate-test.sh",
    "validate:browser": "sh scripts/validate-browser.sh",
    "validate:artifacts": "sh scripts/validate-artifacts.sh",
    "validate:all": "sh scripts/validate-all.sh"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "idb": "^8.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.18",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.0",
    "jsdom": "^26.1.0",
    "playwright": "^1.53.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "vitest": "^3.2.4"
  }
}
